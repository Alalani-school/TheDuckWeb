<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Geometry Dash Web - Epic Extended</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Fredoka+One&display=swap');

        body {
            margin: 0; padding: 0;
            background: #000; color: white;
            font-family: 'Fredoka One', cursive, sans-serif;
            display: flex; justify-content: center; align-items: center;
            height: 100vh; overflow: hidden; user-select: none; touch-action: none; 
        }

        #game-container {
            position: relative; width: 1000px; height: 500px;
            max-width: 100vw; max-height: 100vh;
            background: linear-gradient(to bottom, #154360, #2980b9);
            overflow: hidden; box-shadow: 0 0 40px rgba(0,0,0,1);
            border: 4px solid #fff; border-radius: 10px;
        }

        canvas { display: block; width: 100%; height: 100%; }

        .screen {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            display: flex; flex-direction: column; justify-content: center; align-items: center;
            background: rgba(0, 0, 0, 0.85); z-index: 10; transition: opacity 0.3s ease;
        }

        .hidden { display: none !important; }

        h1 {
            font-size: 54px; margin-bottom: 20px; text-transform: uppercase;
            text-shadow: 5px 5px 0 #000; color: #f1c40f; text-align: center; letter-spacing: 2px;
        }

        .btn {
            background: #27ae60; color: white; border: 4px solid #2ecc71;
            padding: 15px 40px; font-size: 24px; font-family: 'Fredoka One', cursive;
            cursor: pointer; border-radius: 10px; text-transform: uppercase;
            margin: 8px; transition: transform 0.1s; box-shadow: 0 6px 0 #1e8449;
            width: 450px; text-align: center;
        }
        .btn:active { transform: translateY(4px); box-shadow: 0 2px 0 #1e8449; }
        .btn-blue { background: #2980b9; border-color: #3498db; box-shadow: 0 6px 0 #1c5980; }
        .btn-red { background: #e74c3c; border-color: #c0392b; box-shadow: 0 6px 0 #922b21; }
        .btn-purple { background: #8e44ad; border-color: #9b59b6; box-shadow: 0 6px 0 #5b2c6f; width: auto; padding: 15px 50px;}
        .menu-btn { width: auto; padding: 15px 50px; }

        /* Custom Progress Bar in Top Right */
        #progress-container {
            position: absolute; top: 15px; right: 20px;
            width: 300px; height: 30px;
            background: rgba(0,0,0,0.6); border: 3px solid #fff; border-radius: 15px;
            z-index: 5; overflow: hidden;
        }
        #progress-fill {
            height: 100%; width: 0%;
            background: linear-gradient(90deg, #2ecc71, #27ae60);
            transition: width 0.1s linear;
        }
        #progress-text {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            display: flex; justify-content: center; align-items: center;
            font-size: 18px; text-shadow: 2px 2px 0 #000; z-index: 6;
        }

        .skins-container { display: flex; gap: 30px; margin-bottom: 30px; margin-top: 10px; }
        .skin-btn {
            position: relative; width: 70px; height: 70px; border: 4px solid #fff; border-radius: 8px;
            cursor: pointer; box-shadow: 0 6px 0 rgba(0,0,0,0.5); transition: transform 0.2s;
        }
        .skin-btn:hover { transform: scale(1.1); }
        .skin-btn:active { transform: translateY(4px); box-shadow: 0 2px 0 rgba(0,0,0,0.5); }
        .skin-btn.selected::after {
            content: ''; position: absolute; top: -18px; left: -18px; right: -18px; bottom: -18px;
            border: 5px dashed #f1c40f; border-radius: 50%; animation: spin 4s linear infinite; pointer-events: none;
        }
        @keyframes spin { 100% { transform: rotate(360deg); } }
    </style>
</head>
<body>

<div id="game-container">
    <div id="progress-container" class="hidden">
        <div id="progress-fill"></div>
        <div id="progress-text">0%</div>
    </div>
    
    <canvas id="gameCanvas" width="1000" height="500"></canvas>

    <div id="main-menu" class="screen">
        <h1>Geo Dash<br>Web</h1>
        <button class="btn menu-btn" onclick="showLevelSelect()">Play</button>
        <button class="btn menu-btn btn-purple" onclick="showSkinSelect()">Skins</button>
    </div>

    <div id="skin-select" class="screen hidden">
        <h1>Select Skin</h1>
        <div class="skins-container">
            <div class="skin-btn selected" id="skin-0" style="background:#f1c40f;" onclick="setSkin(0)"></div>
            <div class="skin-btn" id="skin-1" style="background:#e74c3c;" onclick="setSkin(1)"></div>
            <div class="skin-btn" id="skin-2" style="background:#3498db;" onclick="setSkin(2)"></div>
            <div class="skin-btn" id="skin-3" style="background:#9b59b6;" onclick="setSkin(3)"></div>
        </div>
        <button class="btn menu-btn btn-red" onclick="showMainMenu()">Back</button>
    </div>

    <div id="level-select" class="screen hidden">
        <h1>Select Level</h1>
        <button class="btn btn-blue" id="btn-lvl-1" onclick="startGame(1)">Level 1 (0%)</button>
        <button class="btn btn-blue" id="btn-lvl-2" onclick="startGame(2)">Level 2 (0%)</button>
        <button class="btn btn-blue" id="btn-lvl-3" onclick="startGame(3)">Level 3: The Gauntlet (0%)</button>
        <button class="btn menu-btn btn-red" onclick="showMainMenu()">Back</button>
    </div>

    <div id="game-over" class="screen hidden">
        <h1 style="color: #e74c3c;">Crashed!</h1>
        <p style="font-size: 28px; margin-bottom: 20px;">Progress: <span id="final-progress">0</span>%</p>
        <button class="btn menu-btn" onclick="retryLevel()">Retry</button>
        <button class="btn menu-btn btn-blue" onclick="showLevelSelect()">Menu</button>
    </div>
    
    <div id="level-complete" class="screen hidden">
        <h1 style="color: #2ecc71;">Level Complete!</h1>
        <button class="btn menu-btn btn-blue" onclick="showLevelSelect()">Menu</button>
    </div>
</div>

<script>
    const canvas = document.getElementById('gameCanvas');
    const ctx = canvas.getContext('2d');

    const ui = {
        main: document.getElementById('main-menu'),
        skins: document.getElementById('skin-select'),
        level: document.getElementById('level-select'),
        over: document.getElementById('game-over'),
        win: document.getElementById('level-complete'),
        progContainer: document.getElementById('progress-container'),
        progFill: document.getElementById('progress-fill'),
        progText: document.getElementById('progress-text'),
        finalProg: document.getElementById('final-progress')
    };

    // Load Save Data
    let savedData = JSON.parse(localStorage.getItem('geoDashSave')) || { 1: 0, 2: 0, 3: 0 };
    function updateMenuButtons() {
        document.getElementById('btn-lvl-1').innerText = `Level 1: The Tunnel (${savedData[1]}%)`;
        document.getElementById('btn-lvl-2').innerText = `Level 2: High Flying (${savedData[2]}%)`;
        document.getElementById('btn-lvl-3').innerText = `Level 3: The Gauntlet (${savedData[3]}%)`;
    }
    updateMenuButtons();

    function saveProgress(level, percent) {
        if (percent > savedData[level]) {
            savedData[level] = percent;
            localStorage.setItem('geoDashSave', JSON.stringify(savedData));
            updateMenuButtons();
        }
    }

    let gameLoop, gameState = 'menu', currentLevel = 1;
    let levelLength = 0, distanceTraveled = 0, isHolding = false, bgOffset = 0;

    const GAME_SPEED = 6.0;         
    const GRAVITY_CUBE = 0.95;       
    const JUMP_FORCE_CUBE = -12.5;  
    const GRAVITY_SHIP = 0.25;      
    const FLIGHT_FORCE_SHIP = -0.5; 
    const SHIP_DRAG = 0.94; 

    const GROUND_Y = 400; 
    const CEILING_Y = 40; 

    const player = { x: 200, y: GROUND_Y - 30, w: 30, h: 30, vy: 0, isGrounded: true, rotation: 0, mode: 'cube', skin: 0 };
    let obstacles = [], particles = [];

    // T: 0=Spike, 1=Block, 2=Ship Portal, 3=Cube Portal
    // Massive, spread out levels!
    const levelData = {
        1: [
            { x: 600, t: 0 }, { x: 1000, t: 0 }, { x: 1030, t: 0 },
            { x: 1500, t: 1 }, { x: 1590, t: 1 }, { x: 1680, t: 1 }, // Spread out blocks
            { x: 2100, t: 1 }, { x: 2190, t: 1, yOff: 30 }, { x: 2280, t: 1, yOff: 60 }, // Spread stairs
            { x: 2500, t: 0, yOff: 90 }, // Spike on stairs
            { x: 3000, t: 2 }, // SHIP PORTAL
            { x: 3500, t: 1, yOff: 0 }, { x: 3500, t: 1, yOff: 300 },
            { x: 4000, t: 1, yOff: 100 }, { x: 4000, t: 1, yOff: 200 },
            { x: 4500, t: 1, yOff: 50 }, { x: 4500, t: 1, yOff: 250 },
            { x: 5000, t: 1, yOff: 0 }, { x: 5000, t: 1, yOff: 300 },
            { x: 5500, t: 1, yOff: 150 }, { x: 6000, t: 1, yOff: 100 },
            { x: 6500, t: 3 }, // CUBE PORTAL
            { x: 7000, t: 0 }, { x: 7030, t: 0 }, { x: 7300, t: 1 }, { x: 7300, t: 0, yOff: 30 },
            { x: 7800, t: 0 }, { x: 7830, t: 0 }, { x: 7860, t: 0 },
            { x: 8400, t: 0 } // End
        ],
        2: [
            { x: 600, t: 1 }, { x: 630, t: 0, yOff: 30 }, { x: 660, t: 1 },
            { x: 1100, t: 0 }, { x: 1130, t: 0 }, { x: 1160, t: 0 },
            { x: 1600, t: 1 }, { x: 1690, t: 1, yOff: 30 }, { x: 1780, t: 1, yOff: 60 },
            { x: 2200, t: 2 }, // SHIP PORTAL
            { x: 2700, t: 1, yOff: 200 }, { x: 2700, t: 0, yOff: 230 },
            { x: 3200, t: 1, yOff: 50 }, { x: 3200, t: 0, yOff: 80 },
            { x: 3700, t: 1, yOff: 250 }, { x: 3700, t: 0, yOff: 280 },
            { x: 4200, t: 1, yOff: 100 }, { x: 4200, t: 0, yOff: 130 },
            { x: 4700, t: 1, yOff: 180 }, { x: 4700, t: 0, yOff: 210 },
            { x: 5200, t: 3 }, // CUBE PORTAL
            { x: 5700, t: 1 }, { x: 5790, t: 1 }, { x: 5880, t: 1, yOff: 30 },
            { x: 6300, t: 0 }, { x: 6330, t: 0 }, { x: 6800, t: 0 },
            { x: 7500, t: 0 } // End
        ],
        3: [
            // Intense Cube Section
            { x: 500, t: 1 }, { x: 590, t: 1 }, { x: 680, t: 1 },
            { x: 1100, t: 1 }, { x: 1100, t: 0, yOff:30 }, { x: 1190, t: 1 }, { x: 1280, t: 1 },
            { x: 1700, t: 0 }, { x: 1730, t: 0 }, { x: 1760, t: 0 },
            { x: 2200, t: 1 }, { x: 2290, t: 1, yOff: 30 }, { x: 2380, t: 1, yOff: 60 }, { x: 2470, t: 1, yOff: 90 },
            { x: 3000, t: 2 }, // SHIP PORTAL
            { x: 3500, t: 1, yOff: 150 }, { x: 3500, t: 0, yOff: 180 }, { x: 3500, t: 0, yOff: 120 },
            { x: 4000, t: 1, yOff: 100 }, { x: 4000, t: 0, yOff: 130 }, { x: 4000, t: 0, yOff: 70 },
            { x: 4500, t: 1, yOff: 200 }, { x: 4500, t: 0, yOff: 230 }, { x: 4500, t: 0, yOff: 170 },
            { x: 5000, t: 3 }, // CUBE PORTAL
            { x: 5500, t: 1 }, { x: 5590, t: 1 }, { x: 5680, t: 1 }, 
            { x: 6000, t: 0 }, { x: 6030, t: 0 }, { x: 6060, t: 0 }, { x: 6090, t: 0 }, // Mega jump
            { x: 6800, t: 0 } // End
        ]
    };

    function show(screen) {
        Object.values(ui).forEach(el => {
            if(el.classList) el.classList.add('hidden');
        });
        if(screen) screen.classList.remove('hidden');
    }

    function showMainMenu() { show(ui.main); }
    function showLevelSelect() { updateMenuButtons(); show(ui.level); }
    function showSkinSelect() { show(ui.skins); }

    function setSkin(id) { 
        player.skin = id; 
        for(let i=0; i<4; i++) document.getElementById('skin-' + i).classList.remove('selected');
        document.getElementById('skin-' + id).classList.add('selected');
    }

    function startGame(levelId) {
        currentLevel = levelId;
        retryLevel();
    }

    function spawnParticles(x, y, color, speedScale = 1) {
        for(let i=0; i<25; i++) {
            particles.push({
                x: x, y: y,
                vx: (Math.random() - 0.5) * 14 * speedScale,
                vy: (Math.random() - 0.5) * 14 * speedScale,
                life: 1.0, color: color
            });
        }
    }

    function retryLevel() {
        show();
        ui.progContainer.classList.remove('hidden');
        player.y = GROUND_Y - player.h; player.vy = 0;
        player.isGrounded = true; player.rotation = 0; player.mode = 'cube';
        distanceTraveled = 0; bgOffset = 0; obstacles = []; particles = [];
        
        ui.progFill.style.width = '0%';
        ui.progText.innerText = '0%';

        gameState = 'playing';

        const data = levelData[currentLevel];
        levelLength = data[data.length - 1].x + 600; 

        data.forEach(obs => {
            obstacles.push({
                x: obs.x, y: GROUND_Y - 30 - (obs.yOff || 0),
                w: 30, h: 30, type: obs.t
            });
        });

        cancelAnimationFrame(gameLoop);
        update();
    }

    function triggerDeath() {
        if(gameState === 'dead') return;
        gameState = 'dead';
        
        const colors = ['#f1c40f', '#e74c3c', '#3498db', '#9b59b6'];
        spawnParticles(player.x + player.w/2, player.y + player.h/2, colors[player.skin], 1.5);

        let percent = Math.floor(Math.min((distanceTraveled / levelLength) * 100, 99));
        saveProgress(currentLevel, percent);

        setTimeout(() => {
            ui.progContainer.classList.add('hidden');
            ui.finalProg.innerText = percent;
            show(ui.over);
        }, 1000);
    }

    function handleInputDown(e) {
        if(e.type !== 'keydown') e.preventDefault();
        if(e.type === 'keydown' && e.repeat) return; 
        const validKeys = ['Space', 'ArrowUp', 'KeyW'];
        if (e.type === 'keydown' && !validKeys.includes(e.code)) return;
        isHolding = true;
        if (gameState === 'playing' && player.mode === 'cube' && player.isGrounded) {
            player.vy = JUMP_FORCE_CUBE; player.isGrounded = false;
        }
    }
    function handleInputUp(e) {
        const validKeys = ['Space', 'ArrowUp', 'KeyW'];
        if (e.type === 'keyup' && !validKeys.includes(e.code)) return;
        isHolding = false;
    }

    window.addEventListener('keydown', handleInputDown);
    window.addEventListener('keyup', handleInputUp);
    canvas.addEventListener('pointerdown', handleInputDown);
    canvas.addEventListener('pointerup', handleInputUp);
    canvas.addEventListener('pointercancel', handleInputUp);

    function drawBackground(ctx) {
        bgOffset -= GAME_SPEED * 0.4;
        if (bgOffset <= -100) bgOffset += 100;
        ctx.strokeStyle = 'rgba(255, 255, 255, 0.08)'; ctx.lineWidth = 2;
        for(let i = 0; i < canvas.width / 100 + 2; i++) {
            ctx.beginPath(); ctx.moveTo(i * 100 + bgOffset, 0); ctx.lineTo(i * 100 + bgOffset, GROUND_Y); ctx.stroke();
        }
        for(let i = 0; i < GROUND_Y / 100; i++) {
            ctx.beginPath(); ctx.moveTo(0, i * 100); ctx.lineTo(canvas.width, i * 100); ctx.stroke();
        }
    }

    function drawPlayer(ctx, x, y, w, h, skinId) {
        ctx.save(); ctx.translate(x + w/2, y + h/2); ctx.rotate(player.rotation * Math.PI / 180);
        const colors = ['#f1c40f', '#e74c3c', '#3498db', '#9b59b6'];
        const accents = ['#d4ac0d', '#c0392b', '#2980b9', '#8e44ad'];
        if (player.mode === 'cube') {
            ctx.fillStyle = colors[skinId]; ctx.fillRect(-w/2, -h/2, w, h);
            ctx.fillStyle = accents[skinId];
            if (skinId === 0) { ctx.fillRect(-w/2, -10, w, 5); ctx.fillRect(-w/2, 5, w, 5); } 
            else if (skinId === 1) { ctx.fillRect(-5, -h/2, 10, h); ctx.fillRect(-w/2, -5, w, 10); } 
            else if (skinId === 2) { ctx.fillRect(-w/2, -h/2, w/2, h/2); ctx.fillRect(0, 0, w/2, h/2); } 
            else if (skinId === 3) { ctx.fillRect(-8, -8, 16, 16); }
            ctx.strokeStyle = '#fff'; ctx.lineWidth = 2; ctx.strokeRect(-w/2, -h/2, w, h);
        } else if (player.mode === 'ship') {
            ctx.fillStyle = colors[skinId];
            ctx.beginPath(); ctx.moveTo(-w, -h/2); ctx.lineTo(w/2, -h/2); ctx.lineTo(w, 0); ctx.lineTo(w/2, h/2); ctx.lineTo(-w, h/2); ctx.closePath(); ctx.fill();
            ctx.strokeStyle = '#fff'; ctx.lineWidth = 2; ctx.stroke();
            ctx.fillStyle = '#85C1E9'; ctx.fillRect(-10, -h/2 + 5, 20, h - 10);
            ctx.fillStyle = '#7f8c8d'; ctx.fillRect(-w - 10, -8, 10, 16);
            ctx.fillStyle = accents[skinId]; ctx.fillRect(-5, -5, 10, 10);
        }
        ctx.restore();
    }

    function update() {
        if (gameState !== 'playing' && gameState !== 'dead') return;
        ctx.clearRect(0, 0, canvas.width, canvas.height);

        drawBackground(ctx);
        ctx.fillStyle = '#1abc9c'; ctx.fillRect(0, GROUND_Y, canvas.width, canvas.height - GROUND_Y);
        ctx.fillStyle = '#fff'; ctx.fillRect(0, GROUND_Y, canvas.width, 3);

        if (player.mode === 'ship') {
            ctx.fillStyle = '#34495e'; ctx.fillRect(0, 0, canvas.width, CEILING_Y);
            ctx.fillStyle = '#fff'; ctx.fillRect(0, CEILING_Y, canvas.width, 3);
        }

        if (gameState === 'playing') {
            distanceTraveled += GAME_SPEED;
            player.isGrounded = false;

            if (player.mode === 'cube') {
                player.vy += GRAVITY_CUBE;
                if (!player.isGrounded) player.rotation += 6; 
            } else if (player.mode === 'ship') {
                if (isHolding) player.vy += FLIGHT_FORCE_SHIP; else player.vy += GRAVITY_SHIP; 
                player.vy *= SHIP_DRAG; player.rotation = player.vy * 5; 
                if(Math.random() > 0.3) particles.push({ x: player.x - 15, y: player.y + player.h/2, vx: -GAME_SPEED * 0.5, vy: (Math.random()-0.5)*2, life: 1.0, color: isHolding ? '#e74c3c' : '#f39c12' });
            }

            player.y += player.vy;

            if (player.y + player.h >= GROUND_Y) {
                player.y = GROUND_Y - player.h; player.vy = 0; player.isGrounded = true;
                if(player.mode === 'cube') {
                    let diff = player.rotation % 90;
                    if(diff !== 0) player.rotation += (diff < 45 ? -diff : (90 - diff));
                } else player.rotation = 0;
            }
            if (player.mode === 'ship' && player.y <= CEILING_Y) { player.y = CEILING_Y; player.vy = 0; }

            const pRect = { l: player.x + 4, r: player.x + player.w - 4, t: player.y + 4, b: player.y + player.h - 4 };

            for (let i = 0; i < obstacles.length; i++) {
                let obs = obstacles[i];
                obs.x -= GAME_SPEED; 

                if (obs.type === 0) { // Spike
                    ctx.fillStyle = '#e74c3c';
                    ctx.beginPath(); ctx.moveTo(obs.x + obs.w/2, obs.y); ctx.lineTo(obs.x + obs.w, obs.y + obs.h); ctx.lineTo(obs.x, obs.y + obs.h); ctx.fill();
                    const oRect = { l: obs.x + 10, r: obs.x + obs.w - 10, t: obs.y + 14, b: obs.y + obs.h };
                    if (pRect.r > oRect.l && pRect.l < oRect.r && pRect.b > oRect.t && pRect.t < oRect.b) triggerDeath();
                } 
                else if (obs.type === 1) { // Block
                    ctx.fillStyle = '#34495e'; ctx.fillRect(obs.x, obs.y, obs.w, obs.h);
                    ctx.strokeStyle = '#fff'; ctx.lineWidth=1; ctx.strokeRect(obs.x, obs.y, obs.w, obs.h);
                    const oRect = { l: obs.x, r: obs.x + obs.w, t: obs.y, b: obs.y + obs.h };
                    if (pRect.r > oRect.l && pRect.l < oRect.r && pRect.b > oRect.t && pRect.t < oRect.b) {
                        let prevBottom = (player.y - player.vy) + player.h;
                        if (player.vy >= 0 && prevBottom <= obs.y + 12 && player.mode === 'cube') {
                            player.y = obs.y - player.h; player.vy = 0; player.isGrounded = true;
                            let diff = player.rotation % 90;
                            if(diff !== 0) player.rotation += (diff < 45 ? -diff : (90 - diff));
                        } else triggerDeath();
                    }
                }
                else if (obs.type === 2 || obs.type === 3) { // Portal (FORCED)
                    const pW = 40;
                    // Portal spans from top to bottom so it cannot be dodged
                    const pTop = CEILING_Y; 
                    const pH = GROUND_Y - CEILING_Y;
                    
                    // Create glowing gradient for portal
                    let gradient = ctx.createLinearGradient(0, pTop, 0, pTop + pH);
                    if (obs.type === 2) { gradient.addColorStop(0, 'rgba(243, 156, 18, 0.2)'); gradient.addColorStop(0.5, 'rgba(243, 156, 18, 0.8)'); gradient.addColorStop(1, 'rgba(243, 156, 18, 0.2)'); }
                    else { gradient.addColorStop(0, 'rgba(39, 174, 96, 0.2)'); gradient.addColorStop(0.5, 'rgba(39, 174, 96, 0.8)'); gradient.addColorStop(1, 'rgba(39, 174, 96, 0.2)'); }

                    ctx.fillStyle = gradient;
                    ctx.fillRect(obs.x, pTop, pW, pH);
                    
                    ctx.strokeStyle = '#fff'; ctx.lineWidth=2; 
                    ctx.strokeRect(obs.x, pTop, pW, pH);

                    const oRect = { l: obs.x, r: obs.x + pW, t: pTop, b: pTop + pH };
                    if (pRect.r > oRect.l && pRect.l < oRect.r && pRect.b > oRect.t && pRect.t < oRect.b) {
                        player.mode = obs.type === 2 ? 'ship' : 'cube';
                        player.rotation = 0;
                    }
                }
            }

            // Update UI Progress Bar
            let rawPercent = (distanceTraveled / levelLength) * 100;
            let percent = Math.floor(Math.max(0, Math.min(rawPercent, 100)));
            ui.progFill.style.width = percent + '%';
            ui.progText.innerText = percent + '%';

            if (distanceTraveled >= levelLength) {
                gameState = 'won';
                saveProgress(currentLevel, 100);
                ui.progContainer.classList.add('hidden');
                show(ui.win);
                return;
            }
        } else {
            // Static obstacles if dead
            obstacles.forEach(obs => {
                if(obs.type === 0) {
                    ctx.fillStyle = '#e74c3c'; ctx.beginPath(); ctx.moveTo(obs.x + obs.w/2, obs.y); ctx.lineTo(obs.x + obs.w, obs.y + obs.h); ctx.lineTo(obs.x, obs.y + obs.h); ctx.fill();
                } else if(obs.type===1) {
                    ctx.fillStyle = '#34495e'; ctx.fillRect(obs.x, obs.y, obs.w, obs.h); ctx.strokeStyle = '#fff'; ctx.lineWidth=1; ctx.strokeRect(obs.x, obs.y, obs.w, obs.h);
                } else if(obs.type===2 || obs.type===3) {
                    const pW = 40; const pTop = CEILING_Y; const pH = GROUND_Y - CEILING_Y;
                    let gradient = ctx.createLinearGradient(0, pTop, 0, pTop + pH);
                    if (obs.type === 2) { gradient.addColorStop(0, 'rgba(243, 156, 18, 0.2)'); gradient.addColorStop(0.5, 'rgba(243, 156, 18, 0.8)'); gradient.addColorStop(1, 'rgba(243, 156, 18, 0.2)'); }
                    else { gradient.addColorStop(0, 'rgba(39, 174, 96, 0.2)'); gradient.addColorStop(0.5, 'rgba(39, 174, 96, 0.8)'); gradient.addColorStop(1, 'rgba(39, 174, 96, 0.2)'); }
                    ctx.fillStyle = gradient; ctx.fillRect(obs.x, pTop, pW, pH); ctx.strokeStyle = '#fff'; ctx.lineWidth=2; ctx.strokeRect(obs.x, pTop, pW, pH);
                }
            });
        }

        if (gameState === 'playing') drawPlayer(ctx, player.x, player.y, player.w, player.h, player.skin);

        for(let i = particles.length - 1; i >= 0; i--) {
            let p = particles[i];
            p.x += p.vx; p.y += p.vy; p.life -= 0.04;
            if(p.life <= 0) { particles.splice(i, 1); continue; }
            ctx.fillStyle = p.color; ctx.globalAlpha = p.life; ctx.fillRect(p.x, p.y, 6, 6); ctx.globalAlpha = 1.0;
        }

        gameLoop = requestAnimationFrame(update);
    }
</script>

