<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Shooter Soccer 3D: First Person & Replays</title>
    <style>
        :root {
            --cr-color: #ffffff;
            --cr-size: 14px;
            --cr-x: 0px;
            --cr-y: 0px;
            --cr-rot: 0deg;
            --cr-length: 20px;
        }

        body { margin: 0; overflow: hidden; background-color: #000; font-family: 'Arial Black', sans-serif; user-select: none; }
        #game-container { position: absolute; top: 0; left: 0; width: 100%; height: 100%; filter: brightness(1); transition: filter 0.2s; }
        .overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: flex; flex-direction: column; justify-content: center; align-items: center; background: rgba(0, 0, 0, 0.75); backdrop-filter: blur(5px); z-index: 50; }
        .hidden { display: none !important; }
        
        h1 { font-size: 60px; color: white; text-shadow: 4px 4px 0 #00aaff; margin-bottom: 40px; letter-spacing: 2px; text-align: center; }
        h2 { font-size: 30px; color: white; margin-bottom: 20px; text-transform: uppercase; }
        
        .btn { background: #eee; color: #111; border: 4px solid #fff; padding: 15px 40px; margin: 10px; font-size: 24px; font-family: inherit; font-weight: bold; cursor: pointer; border-radius: 8px; transition: 0.2s; width: 300px; text-transform: uppercase; }
        .btn:hover:not(.disabled) { background: #00aaff; color: white; border-color: #00ffff; transform: scale(1.05); }
        .grid-container { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; max-width: 600px; }
        .mode-card { background: #222; border: 3px solid #555; color: white; padding: 30px 20px; font-size: 22px; font-family: inherit; cursor: pointer; border-radius: 10px; transition: 0.2s; text-align: center; }
        .mode-card:hover { border-color: #00aaff; background: #334; transform: scale(1.05); }
        .back-btn { position: absolute; top: 30px; left: 30px; background: transparent; color: white; border: 3px solid white; font-size: 24px; width: 50px; height: 50px; cursor: pointer; font-family: inherit; border-radius: 8px; display: flex; justify-content: center; align-items: center;}
        .back-btn:hover { background: #ff0055; border-color: #ff0055; color: white; }
        
        #game-ui { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 10; }
        #instructions { position: absolute; top: 20px; left: 20px; color: white; text-shadow: 2px 2px 0 #000; }
        #scoreboard { position: absolute; top: 20px; left: 50%; transform: translateX(-50%); font-size: 40px; color: white; text-shadow: 3px 3px 0 #000; text-align: center; }
        #wave-counter { position: absolute; top: 70px; left: 50%; transform: translateX(-50%); font-size: 24px; color: #22dd22; text-shadow: 2px 2px 0 #000; display: none; }
        #replay-text { position: absolute; top: 80px; left: 50%; transform: translateX(-50%); font-size: 30px; color: #ffaa00; text-shadow: 2px 2px 0 #000; display: none; animation: flash 1.5s infinite; text-align: center;}
        @keyframes flash { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
        .blue { color: #00aaff; } .red { color: #ff0055; }
        
        #pause-btn { position: absolute; top: 20px; right: 20px; background: #222; color: white; border: 3px solid #555; padding: 10px 15px; font-size: 20px; cursor: pointer; border-radius: 8px; pointer-events: auto; }
        #pause-btn:hover { background: #444; border-color: #fff; }
        #pause-menu { display: none; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: rgba(0,0,0,0.9); border: 4px solid #00aaff; padding: 40px; text-align: center; border-radius: 12px; pointer-events: auto; }
        #death-screen { background: rgba(150, 0, 0, 0.85); border: 6px solid #ff0000; }
        #death-screen h1 { color: #ff0000; text-shadow: 4px 4px 0 #000; font-size: 80px; margin-bottom: 20px; }
        
        /* SETTINGS MENU */
        .settings-panel { background: #222; border: 4px solid #555; border-radius: 12px; padding: 30px; color: white; display: flex; gap: 40px; text-align: left; }
        .settings-col { display: flex; flex-direction: column; gap: 15px; }
        .settings-col label { font-size: 16px; font-weight: normal; font-family: sans-serif; }
        input[type="range"] { width: 100%; cursor: pointer; }
        input[type="color"] { cursor: pointer; width: 50px; height: 30px; padding: 0; border: none; background: transparent; }
        input[type="number"] { width: 60px; padding: 5px; font-family: inherit; border-radius: 4px; border: 2px solid #555; background: #111; color: white; }
        .preview-box { width: 150px; height: 150px; background: #1a1a24; border: 3px solid #555; border-radius: 8px; position: relative; overflow: hidden; display: flex; justify-content: center; align-items: center; }
        .preview-label { position: absolute; top: 5px; left: 10px; font-size: 12px; color: #aaa; font-family: sans-serif; }

        /* TOGGLE SWITCH CSS */
        .switch { position: relative; display: inline-block; width: 50px; height: 26px; }
        .switch input { opacity: 0; width: 0; height: 0; }
        .slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: #555; transition: .4s; border-radius: 34px; border: 2px solid #333;}
        .slider:before { position: absolute; content: ""; height: 18px; width: 18px; left: 2px; bottom: 2px; background-color: white; transition: .4s; border-radius: 50%; }
        input:checked + .slider { background-color: #00aaff; border-color: #00aaff; }
        input:checked + .slider:before { transform: translateX(24px); }

        /* SKINS MENU */
        #skins-container { display: flex; width: 90%; max-width: 1000px; height: 75%; background: #222; border: 4px solid #555; border-radius: 12px; overflow: hidden; }
        #skins-sidebar { width: 250px; background: #1a1a1a; border-right: 4px solid #444; display: flex; flex-direction: column; }
        .sidebar-btn { background: transparent; color: white; border: none; padding: 20px; text-align: left; font-size: 18px; font-family: inherit; font-weight: bold; cursor: pointer; border-bottom: 2px solid #333; transition: 0.2s; text-transform: uppercase; }
        .sidebar-btn:hover { background: #333; }
        .sidebar-btn.active { background: #00aaff; color: white; border-left: 6px solid #fff; }
        #skins-main { flex-grow: 1; display: flex; flex-direction: column; }
        #skins-topbar { display: flex; justify-content: space-between; align-items: center; padding: 15px 20px; border-bottom: 2px solid #444; background: #111; }
        #skins-topbar h2 { margin: 0; font-size: 24px; color: #ffaa00; }
        #skins-preview-area { height: 250px; background: #151515; display: flex; justify-content: center; align-items: center; border-bottom: 4px solid #444; box-shadow: inset 0 0 20px rgba(0,0,0,0.8); }
        #skin-3d-preview { width: 200px; height: 200px; }
        #skins-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 15px; padding: 20px; overflow-y: auto; flex-grow: 1; background: #222; }
        .skin-card { background: #333; border: 4px solid #555; border-radius: 8px; height: 120px; display: flex; flex-direction: column; justify-content: center; align-items: center; cursor: pointer; transition: 0.2s; position: relative; }
        .skin-card:hover { border-color: #00aaff; background: #445; transform: translateY(-5px); }
        .skin-card.selected { border-color: #00ff00; background: #1a331a; }
        .skin-card-name { color: white; font-family: sans-serif; font-weight: bold; font-size: 16px; margin-top: 10px; text-align: center; pointer-events: none;}
        .skin-card-color { width: 40px; height: 40px; border-radius: 50%; border: 3px solid #fff; pointer-events: none; }

        /* CROSSHAIR LOGIC */
        #crosshair, #crosshair-preview { position: absolute; top: calc(50% + var(--cr-y)); left: calc(50% + var(--cr-x)); transform: translate(-50%, -50%) rotate(var(--cr-rot)); pointer-events: none; display: none; }
        #crosshair { z-index: 100; mix-blend-mode: difference; } 
        #crosshair-preview { mix-blend-mode: normal; position: relative; top: var(--cr-y); left: var(--cr-x); display: block; }
        .circle { width: var(--cr-size); height: var(--cr-size); border: 3px solid var(--cr-color); border-radius: 50%; background: transparent; }
        .dot { width: var(--cr-size); height: var(--cr-size); background: var(--cr-color); border-radius: 50%; border: none; }
        .cross { width: var(--cr-length); height: var(--cr-length); background: transparent; border: none; border-radius: 0; }
        .cross::before { content: ''; position: absolute; top: calc(50% - (var(--cr-size)/2)); left: 0; width: var(--cr-length); height: var(--cr-size); background: var(--cr-color); }
        .cross::after { content: ''; position: absolute; top: 0; left: calc(50% - (var(--cr-size)/2)); width: var(--cr-size); height: var(--cr-length); background: var(--cr-color); }
    </style>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
</head>
<body>

    <div id="game-container"></div> 

    <div id="main-menu" class="overlay">
        <h1>SHOOTER SOCCER</h1>
        <button class="btn" onclick="openSkinShop()">SKIN SHOP</button>
        <button class="btn" onclick="showScreen('mode-select')">PLAY</button>
        <button class="btn" onclick="showScreen('settings-menu')">Settings</button>
    </div>

    <div id="skins-menu" class="overlay hidden">
        <div id="skins-container">
            <div id="skins-sidebar">
                <button class="sidebar-btn active" onclick="setSkinCategory('character')">Character</button>
                <button class="sidebar-btn" onclick="setSkinCategory('enemies')">Enemies</button>
                <button class="sidebar-btn" onclick="setSkinCategory('zombie')">Zombies</button>
                <button class="sidebar-btn" onclick="setSkinCategory('soccer')">Soccer Ball</button>
                <button class="sidebar-btn" onclick="setSkinCategory('basketball')">Basketball</button>
                <button class="sidebar-btn" onclick="setSkinCategory('volleyball')">Volleyball</button>
            </div>
            <div id="skins-main">
                <div id="skins-topbar">
                    <h2 id="skin-category-title">CHARACTER SKINS</h2>
                    <button class="btn" style="width: auto; padding: 10px 20px; margin: 0; font-size: 18px;" onclick="closeSkinShop()">✖ Exit to Menu</button>
                </div>
                <div id="skins-preview-area">
                    <div id="skin-3d-preview"></div>
                </div>
                <div id="skins-grid"></div>
            </div>
        </div>
    </div>

    <div id="settings-menu" class="overlay hidden">
        <button class="back-btn" onclick="showScreen('main-menu')">✖</button>
        <h2>SETTINGS</h2>
        <div class="settings-panel">
            <div class="settings-col" style="min-width: 250px;">
                <h3 style="margin: 0; color: #00aaff;">GENERAL</h3>
                <div>
                    <label>Brightness: <span id="val-brightness">1.0</span></label><br>
                    <input type="range" id="set-brightness" min="0.2" max="2" step="0.1" value="1.0" oninput="updateSetting('brightness', this.value)">
                </div>
                <div>
                    <label>Render Distance: <span id="val-renderDist">1000</span></label><br>
                    <input type="range" id="set-renderDist" min="200" max="2500" step="100" value="1000" oninput="updateSetting('renderDistance', this.value)">
                </div>
                
                <div style="display: flex; align-items: center; justify-content: space-between; margin-top: 20px; padding: 10px; background: #111; border-radius: 8px; border: 2px solid #444;">
                    <label style="color: #00ffaa; font-weight: bold; font-family: 'Arial Black', sans-serif;">FIRST PERSON MODE</label>
                    <label class="switch">
                        <input type="checkbox" id="set-fpv" onchange="updateSetting('firstPerson', this.checked)">
                        <span class="slider"></span>
                    </label>
                </div>

                <p style="color: #aaa; font-family: sans-serif; font-size: 12px; margin-top: auto;">All settings save automatically.</p>
            </div>

            <div class="settings-col" style="min-width: 300px; border-left: 2px solid #444; padding-left: 40px;">
                <h3 style="margin: 0; color: #00aaff;">AIMING CURSOR</h3>
                <div style="display: flex; gap: 10px;">
                    <button id="btn-dot" class="btn" style="width:auto; padding: 5px 15px; margin: 0; font-size: 16px;" onclick="updateSetting('crossType', 'dot')">Dot</button>
                    <button id="btn-circle" class="btn" style="width:auto; padding: 5px 15px; margin: 0; font-size: 16px;" onclick="updateSetting('crossType', 'circle')">Circle</button>
                    <button id="btn-cross" class="btn" style="width:auto; padding: 5px 15px; margin: 0; font-size: 16px;" onclick="updateSetting('crossType', 'cross')">Cross</button>
                </div>
                <div style="display: flex; gap: 20px; align-items: center;">
                    <label>Color:</label> 
                    <input type="color" id="set-color" value="#ffffff" oninput="updateSetting('crossColor', this.value)">
                </div>
                <div>
                    <label>Size / Thickness: <span id="val-size">14</span></label><br>
                    <input type="range" id="set-size" min="2" max="50" step="1" value="14" oninput="updateSetting('crossSize', this.value)">
                </div>
                <div style="display: flex; gap: 10px; align-items: center;">
                    <label>Pos X:</label> <input type="number" id="set-posX" value="0" oninput="updateSetting('crossX', this.value)">
                    <label>Y:</label> <input type="number" id="set-posY" value="0" oninput="updateSetting('crossY', this.value)">
                </div>
                <div>
                    <label>Rotation: <span id="val-rot">0</span>°</label><br>
                    <input type="range" id="set-rot" min="0" max="360" step="1" value="0" oninput="updateSetting('crossRot', this.value)">
                </div>
                <div id="cross-only-settings" style="border: 2px dashed #555; padding: 10px; border-radius: 5px;">
                    <label style="color: #ffaa00; font-weight: bold;">CROSS ONLY</label><br>
                    <label>Line Length: <span id="val-length">20</span></label><br>
                    <input type="range" id="set-length" min="5" max="100" step="1" value="20" oninput="updateSetting('crossLength', this.value)">
                </div>
            </div>

            <div class="settings-col" style="align-items: center;">
                <div class="preview-box">
                    <span class="preview-label">PREVIEW</span>
                    <div id="crosshair-preview" class="circle"></div>
                </div>
                <button class="btn" style="width: 150px; font-size: 16px; padding: 10px; margin-top: auto;" onclick="showScreen('main-menu')">DONE</button>
            </div>
        </div>
    </div>

    <div id="mode-select" class="overlay hidden">
        <button class="back-btn" onclick="showScreen('main-menu')">✖</button>
        <h2>SELECT GAME MODE</h2>
        <div class="grid-container">
            <button class="mode-card" onclick="selectMode('soccer')">Soccer</button>
            <button class="mode-card" onclick="selectMode('basketball')">Basketball</button>
            <button class="mode-card" onclick="selectMode('volleyball')">Volleyball</button>
            <button class="mode-card" onclick="selectMode('zombie')">Zombie Survival</button>
        </div>
    </div>

    <div id="soccer-sub" class="overlay hidden">
        <button class="back-btn" onclick="showScreen('mode-select')">✖</button>
        <h2 id="team-size-title">TEAM SIZE</h2>
        <button class="btn" onclick="startGame(1)">1 v 1</button>
        <button class="btn" onclick="startGame(2)">2 v 2</button>
        <button class="btn" onclick="startGame(3)">3 v 3</button>
    </div>

    <div id="death-screen" class="overlay hidden">
        <h1>YOU DIED</h1>
        <h2 id="death-wave-text" style="color: white; margin-bottom: 40px;">You survived until Wave X</h2>
        <button class="btn" onclick="startGame(currentTeamSize)">RETRY</button>
        <button class="btn" onclick="exitToMainMenu()">MAIN MENU</button>
    </div>

    <div id="game-ui" class="hidden">
        <div id="instructions">
            <h3 style="margin:0;">SHOOTER SOCCER</h3>
            <p style="margin:5px 0 0 0; font-size:14px;">WASD: Move | SHIFT: Dash | SPACE: Double Jump<br>LEFT CLICK: Shoot</p>
        </div>
        <div id="scoreboard"><span class="blue" id="score-p1">0</span> - <span class="red" id="score-p2">0</span></div>
        <div id="wave-counter">WAVE: <span id="wave-num">1</span></div>
        <div id="replay-text">▶ REPLAY<br><span id="replay-scorer" style="font-size: 20px; color: #fff;"></span></div>
        <div id="crosshair" class="circle"></div>
        <button id="pause-btn" onclick="pauseGame()">⏸</button>
        <div id="pause-menu">
            <h2>GAME PAUSED</h2>
            <button class="btn" style="width:200px; padding:10px;" onclick="resumeGame()">▶ Resume</button><br>
            <button class="btn" style="width:200px; padding:10px; background:#ff0055; border-color:#fff; color:white;" onclick="exitToMainMenu()">Exit to Menu</button>
        </div>
    </div>

    <script>
        // ==========================================
        // SETTINGS & SAVING SYSTEM
        // ==========================================
        let gameSettings = {
            firstPerson: false,
            brightness: 1.0, renderDistance: 1000, crossType: 'circle', crossColor: '#ffffff',
            crossSize: 14, crossX: 0, crossY: 0, crossRot: 0, crossLength: 20,
            skins: { character: 'duck', enemies: 'bean_red', soccer: 'classic', basketball: 'classic', volleyball: 'classic', zombie: 'chicken' }
        };

        const SKIN_DATA = {
            character: [{ id: 'duck', name: 'Rubber Duck', type: 'duck', primaryColor: 0xffdd00 }, { id: 'bean_blue', name: 'Blue Bean', type: 'bean', primaryColor: 0x0088ff }, { id: 'robot', name: 'Blocky Bot', type: 'robot', primaryColor: 0xaaaaaa }],
            enemies: [{ id: 'chicken', name: 'Angry Chicken', type: 'chicken', primaryColor: 0xffffff }, { id: 'bean_red', name: 'Red Bean', type: 'bean', primaryColor: 0xff0055 }, { id: 'robot', name: 'Blocky Bot', type: 'robot', primaryColor: 0xaaaaaa }],
            zombie: [{ id: 'chicken', name: 'Zombie Chicken', type: 'chicken', primaryColor: 0x99dd99 }, { id: 'bean_green', name: 'Sludge Bean', type: 'bean', primaryColor: 0x22dd22 }, { id: 'duck', name: 'Infected Duck', type: 'duck', primaryColor: 0x55aa00 }],
            soccer: [{ id: 'classic', name: 'Classic Cyan', type: 'ball', primaryColor: 0x00ffff }, { id: 'fire', name: 'Fireball', type: 'ball', primaryColor: 0xff5500 }, { id: 'neon', name: 'Neon Green', type: 'ball', primaryColor: 0x00ff00 }],
            basketball: [{ id: 'classic', name: 'Classic Orange', type: 'ball', primaryColor: 0xff8800 }, { id: 'street', name: 'Street Ball', type: 'ball', primaryColor: 0x888888 }, { id: 'pro', name: 'Pro Gold', type: 'ball', primaryColor: 0xffcc00 }],
            volleyball: [{ id: 'classic', name: 'Classic White', type: 'ball', primaryColor: 0xffffff }, { id: 'beach', name: 'Beach Vibes', type: 'ball', primaryColor: 0xffff00 }, { id: 'pink', name: 'Hot Pink', type: 'ball', primaryColor: 0xff00ff }]
        };

        function loadSettings() {
            let saved = localStorage.getItem('shooterSoccerConfigV3');
            if (saved) {
                let parsed = JSON.parse(saved);
                gameSettings = { ...gameSettings, ...parsed };
                if(!gameSettings.skins) gameSettings.skins = { character: 'duck', enemies: 'bean_red', soccer: 'classic', basketball: 'classic', volleyball: 'classic', zombie: 'chicken' };
            }
            applySettings(); updateSettingsUI();
        }

        function updateSetting(key, val) {
            gameSettings[key] = val; applySettings(); updateSettingsUI();
            localStorage.setItem('shooterSoccerConfigV3', JSON.stringify(gameSettings)); 
        }

        function saveSkins() { localStorage.setItem('shooterSoccerConfigV3', JSON.stringify(gameSettings)); }

        function applySettings() {
            let root = document.documentElement;
            root.style.setProperty('--cr-color', gameSettings.crossColor); root.style.setProperty('--cr-size', gameSettings.crossSize + 'px');
            root.style.setProperty('--cr-x', gameSettings.crossX + 'px'); root.style.setProperty('--cr-y', gameSettings.crossY + 'px');
            root.style.setProperty('--cr-rot', gameSettings.crossRot + 'deg'); root.style.setProperty('--cr-length', gameSettings.crossLength + 'px');
            document.getElementById('crosshair').className = gameSettings.crossType;
            document.getElementById('crosshair-preview').className = gameSettings.crossType;
            document.getElementById('cross-only-settings').style.display = (gameSettings.crossType === 'cross') ? 'block' : 'none';
            document.getElementById('game-container').style.filter = `brightness(${gameSettings.brightness})`;

            if (typeof camera !== 'undefined') { camera.far = parseFloat(gameSettings.renderDistance); camera.updateProjectionMatrix(); scene.fog.far = parseFloat(gameSettings.renderDistance) * 0.15; }
        }

        function updateSettingsUI() {
            document.getElementById('set-brightness').value = gameSettings.brightness; document.getElementById('val-brightness').innerText = parseFloat(gameSettings.brightness).toFixed(1);
            document.getElementById('set-renderDist').value = gameSettings.renderDistance; document.getElementById('val-renderDist').innerText = gameSettings.renderDistance;
            document.getElementById('set-fpv').checked = gameSettings.firstPerson;
            ['dot', 'circle', 'cross'].forEach(type => { document.getElementById('btn-' + type).classList.toggle('active', gameSettings.crossType === type); });
            document.getElementById('set-color').value = gameSettings.crossColor; document.getElementById('set-size').value = gameSettings.crossSize; document.getElementById('val-size').innerText = gameSettings.crossSize;
            document.getElementById('set-posX').value = gameSettings.crossX; document.getElementById('set-posY').value = gameSettings.crossY;
            document.getElementById('set-rot').value = gameSettings.crossRot; document.getElementById('val-rot').innerText = gameSettings.crossRot;
            document.getElementById('set-length').value = gameSettings.crossLength; document.getElementById('val-length').innerText = gameSettings.crossLength;
        }

        // ==========================================
        // 3D MODEL GENERATORS
        // ==========================================
        function createCharacterBySkin(skinId, category) {
            const skinInfo = SKIN_DATA[category].find(s => s.id === skinId);
            if (!skinInfo) return createBeanCharacter(0xffffff);
            if (skinInfo.type === 'duck') return createDuckCharacter(skinInfo.primaryColor);
            if (skinInfo.type === 'chicken') return createChickenCharacter(skinInfo.primaryColor);
            if (skinInfo.type === 'robot') return createRobotCharacter(skinInfo.primaryColor);
            return createBeanCharacter(skinInfo.primaryColor); 
        }

        function createBeanCharacter(colorHex) {
            const group = new THREE.Group(); const mat = new THREE.MeshStandardMaterial({ color: colorHex });
            const bot = new THREE.Mesh(new THREE.SphereGeometry(0.75, 16, 16), mat); bot.position.y = 0.75; bot.castShadow = true; group.add(bot);
            const mid = new THREE.Mesh(new THREE.CylinderGeometry(0.75, 0.75, 1.5, 16), mat); mid.position.y = 1.5; mid.castShadow = true; group.add(mid);
            const top = new THREE.Mesh(new THREE.SphereGeometry(0.75, 16, 16), mat); top.position.y = 2.25; top.castShadow = true; group.add(top);
            const eyeM = new THREE.MeshBasicMaterial({ color: 0x000000 });
            const le = new THREE.Mesh(new THREE.SphereGeometry(0.12, 8, 8), eyeM); le.position.set(-0.25, 2.35, -0.65); group.add(le);
            const re = new THREE.Mesh(new THREE.SphereGeometry(0.12, 8, 8), eyeM); re.position.set(0.25, 2.35, -0.65); group.add(re);
            const mo = new THREE.Mesh(new THREE.BoxGeometry(0.25, 0.05, 0.1), eyeM); mo.position.set(0, 2.15, -0.72); group.add(mo);
            group.vel = new THREE.Vector3(0,0,0); return group;
        }

        function createDuckCharacter(colorHex) {
            const group = new THREE.Group();
            const mainMat = new THREE.MeshStandardMaterial({ color: colorHex }); const orangeMat = new THREE.MeshStandardMaterial({ color: 0xff8800 }); const blackMat = new THREE.MeshBasicMaterial({ color: 0x000000 });
            const body = new THREE.Mesh(new THREE.SphereGeometry(1.2, 16, 16), mainMat); body.scale.set(1, 0.8, 1.2); body.position.y = 1; body.castShadow = true; group.add(body);
            const head = new THREE.Mesh(new THREE.SphereGeometry(0.7, 16, 16), mainMat); head.position.set(0, 2.2, -0.6); head.castShadow = true; group.add(head);
