            if (currentMode === 'volleyball') { if (allies.includes(char) && char.position.z < 1.5) char.position.z = 1.5; else if (enemies.includes(char) && char.position.z > -1.5) char.position.z = -1.5; }
        }

        function animate() {
            requestAnimationFrame(animate);

            if (gameState === 'MAIN_MENU') { menuOrbitAngle += 0.002; camera.position.set(Math.sin(menuOrbitAngle) * 80, 30, Math.cos(menuOrbitAngle) * 80); camera.lookAt(0, 0, 0); }
            else if (gameState === 'PLAYING') {
                if (slowMoTimer > 0) { timeScale = 0.3; slowMoTimer--; } else { timeScale = 1.0; }

                if(currentMode !== 'zombie') {
                    let snap = { 
                        allies: allies.map(a => ({x:a.position.x, y:a.position.y, z:a.position.z, r:a.rotation.y})), 
                        enemies: enemies.map(e => ({x:e.position.x, y:e.position.y, z:e.position.z, r:e.rotation.y})), 
                        b: {x:ball.position.x, y:ball.position.y, z:ball.position.z, rx:ball.rotation.x, ry:ball.rotation.y, rz:ball.rotation.z},
                        projs: projectiles.map(p => ({ x: p.mesh.position.x, y: p.mesh.position.y, z: p.mesh.position.z, rx: p.mesh.rotation.x, ry: p.mesh.rotation.y, rz: p.mesh.rotation.z, color: p.pColor }))
                    };
                    historyBuffer.push(snap); if (historyBuffer.length > MAX_HISTORY) historyBuffer.shift();
                }

                let isDashing = keys['ShiftLeft']; let accel = isDashing ? 0.08 : 0.04; let pInputX = 0, pInputZ = 0;
                if (keys['KeyW']) { pInputZ += Math.cos(yawAngle); pInputX += Math.sin(yawAngle); } if (keys['KeyS']) { pInputZ -= Math.cos(yawAngle); pInputX -= Math.sin(yawAngle); }
                if (keys['KeyA']) { pInputZ += Math.cos(yawAngle + Math.PI/2); pInputX += Math.sin(yawAngle + Math.PI/2); } if (keys['KeyD']) { pInputZ += Math.cos(yawAngle - Math.PI/2); pInputX += Math.sin(yawAngle - Math.PI/2); }
                
                if (pInputX !== 0 || pInputZ !== 0) {
                    let len = Math.sqrt(pInputX*pInputX + pInputZ*pInputZ); player.vel.x += (pInputX / len) * accel; player.vel.z += (pInputZ / len) * accel;
                    if (isDashing && Math.random() < 0.5) { let d = new THREE.Mesh(new THREE.BoxGeometry(0.4, 0.4, 0.4), new THREE.MeshBasicMaterial({ color: 0x00ffff })); d.position.copy(player.position); d.position.y += 0.5; scene.add(d); particles.push({ mesh: d, life: 15, maxLife: 15, isTrail: true, vel: new THREE.Vector3(0,0,0) }); }
                }
                player.rotation.y = yawAngle + Math.PI;

                if (fireCooldown > 0) fireCooldown -= 1 * timeScale;
                if ((isMouseDown || keys['ArrowUp']) && document.pointerLockElement === renderer.domElement && fireCooldown <= 0) {
                    fireCooldown = 8; cameraShake = 0.3; 
                    let aimTarget = player.position.clone().add(new THREE.Vector3(Math.sin(yawAngle) * 100, Math.sin(pitchAngle) * 100 + 5, Math.cos(yawAngle) * 100));
                    const gunPos = new THREE.Vector3(); playerGunData.barrel.getWorldPosition(gunPos);
                    let shootDir = new THREE.Vector3().subVectors(aimTarget, gunPos).normalize();
                    const bullet = new THREE.Mesh(new THREE.CylinderGeometry(0.15, 0.15, 1.2, 8).rotateX(Math.PI/2), new THREE.MeshBasicMaterial({ color: 0x0088ff })); 
                    bullet.position.copy(gunPos).add(shootDir.clone().multiplyScalar(0.7)); bullet.lookAt(bullet.position.clone().add(shootDir)); scene.add(bullet); 
                    projectiles.push({ mesh: bullet, velocity: shootDir.multiplyScalar(4.0), life: 30, pColor: 0x0088ff, tColor: 0x00ffff, ownerChar: player });
                }

                allies.forEach((ally, i) => {
                    if(i===0) return; let tPos = ball.position; if(currentMode === 'zombie') tPos = enemies.length > 0 ? enemies[0].position : player.position;
                    let target = new THREE.Vector3(tPos.x + (Math.random()-0.5)*10, ally.position.y, tPos.z + 5); let dist = ally.position.distanceTo(tPos); let dir = new THREE.Vector3().subVectors(target, ally.position).normalize();
                    ally.vel.x += dir.x * 0.04; ally.vel.z += dir.z * 0.04; ally.lookAt(tPos); ally.rotateY(Math.PI);
                    if(Math.random() < 0.02 && dist < 30 && currentMode !== 'zombie') {
                        let shootDir = new THREE.Vector3().subVectors(tPos, ally.position).normalize(); shootDir.y += 0.1; shootDir.normalize(); 
                        const bullet = new THREE.Mesh(new THREE.CylinderGeometry(0.15, 0.15, 1.2, 8).rotateX(Math.PI/2), new THREE.MeshBasicMaterial({ color: 0x00aaff })); const gunPos = new THREE.Vector3(); allyGuns[i].barrel.getWorldPosition(gunPos);
                        bullet.position.copy(gunPos).add(shootDir.clone().multiplyScalar(0.7)); bullet.lookAt(bullet.position.clone().add(shootDir)); scene.add(bullet); projectiles.push({ mesh: bullet, velocity: shootDir.multiplyScalar(4.0), life: 30, pColor: 0x00aaff, tColor: 0x00ffff, ownerChar: ally });
                    }
                });

                if (currentMode === 'zombie' && enemies.length === 0) { zombieWave++; document.getElementById('wave-num').innerText = zombieWave; spawnZombies(zombieWave * currentTeamSize * 2); }

                for (let i = enemies.length - 1; i >= 0; i--) {
                    let enemy = enemies[i]; let tObj = currentMode === 'zombie' ? player : ball; let target = new THREE.Vector3(tObj.position.x, enemy.position.y, tObj.position.z - (currentMode === 'zombie' ? 0 : 5));
                    let dist = enemy.position.distanceTo(tObj.position); let dir = new THREE.Vector3().subVectors(target, enemy.position).normalize();
                    let speed = currentMode === 'zombie' ? 0.045 + (zombieWave * 0.002) : 0.04; enemy.vel.x += dir.x * speed; enemy.vel.z += dir.z * speed; enemy.lookAt(tObj.position); enemy.rotateY(Math.PI);
                    if (currentMode === 'zombie' && dist < 1.8) { gameOver(); }
                    if(currentMode !== 'zombie' && Math.random() < 0.02 && dist < 30) {
                        let shootDir = new THREE.Vector3().subVectors(tObj.position, enemy.position).normalize(); shootDir.y += 0.1; shootDir.normalize(); 
                        const bullet = new THREE.Mesh(new THREE.CylinderGeometry(0.15, 0.15, 1.2, 8).rotateX(Math.PI/2), new THREE.MeshBasicMaterial({ color: 0xff0055 })); const gunPos = new THREE.Vector3(); enemyGuns[i].barrel.getWorldPosition(gunPos);
                        bullet.position.copy(gunPos).add(shootDir.clone().multiplyScalar(0.7)); bullet.lookAt(bullet.position.clone().add(shootDir)); scene.add(bullet); projectiles.push({ mesh: bullet, velocity: shootDir.multiplyScalar(4.0), life: 30, pColor: 0xff0055, tColor: 0xff5555, ownerChar: enemy });
                    }
                }

                let allChars = [...allies, ...enemies];
                for(let i=0; i<allChars.length; i++) {
                    for(let j=i+1; j<allChars.length; j++) {
                        let charA = allChars[i]; let charB = allChars[j]; let dist = charA.position.distanceTo(charB.position);
                        if (dist > 0.01 && dist < 1.8) { let pushDir = new THREE.Vector3().subVectors(charA.position, charB.position).normalize().multiplyScalar(0.05); charA.position.add(pushDir); charB.position.sub(pushDir); }
                    }
                }

                allChars.forEach(char => {
                    char.position.x += char.vel.x * timeScale; char.position.z += char.vel.z * timeScale; char.position.y += char.vel.y * timeScale;
                    char.vel.x *= 0.9; char.vel.z *= 0.9; char.vel.y -= GRAVITY * timeScale;
                    if (char.position.y <= 0) { char.position.y = 0; char.vel.y = 0; if(char === player) canDoubleJump = false; }
                    checkWallCollisions(char); 
                    if (currentMode !== 'zombie' && ball.visible) {
                        let distToBall = char.position.distanceTo(ball.position);
                        if (distToBall < ballRadius + 1.5) {
                            lastTouchChar = char; // Record physical touch
                            let pushDir = new THREE.Vector3().subVectors(ball.position, char.position).normalize();
                            ballVelocity.add(pushDir.multiplyScalar(0.8)); char.vel.add(pushDir.multiplyScalar(-0.2)); 
                        }
                    }
                });

                for(let i = projectiles.length - 1; i >= 0; i--) {
                    let p = projectiles[i]; p.mesh.position.add(p.velocity.clone().multiplyScalar(timeScale)); p.life -= 1 * timeScale; let hitBall = false;
                    if (currentMode !== 'zombie' && p.mesh.position.distanceTo(ball.position) < ballRadius + 0.6) {
                        hitBall = true; lastTouchChar = p.ownerChar; // Record bullet touch
                        let pushDir = p.velocity.clone().normalize();
                        if (currentMode === 'basketball') { ballVelocity.add(pushDir.multiplyScalar(1.2)); ballVelocity.y += 1.8; slowMoTimer = 60; } else { ballVelocity.add(pushDir.multiplyScalar(1.5)); }
                        ballTargetScale = 1.4; spawnExplosion(p.mesh.position, p.tColor, 5);
                    }
                    let hitCharacter = false;
                    if (currentMode === 'zombie') {
                        for (let j = enemies.length - 1; j >= 0; j--) {
                            let e = enemies[j]; let dist2D = Math.hypot(p.mesh.position.x - e.position.x, p.mesh.position.z - e.position.z);
                            if (p.ownerChar === player && dist2D < 2.5 && p.mesh.position.y < 4) { scene.remove(e); enemies.splice(j, 1); hitCharacter = true; spawnExplosion(e.position, 0x22dd22, 10); break; }
                        }
                    }
                    if (p.life <= 0 || hitBall || hitCharacter || p.mesh.position.y < 0) { scene.remove(p.mesh); projectiles.splice(i, 1); }
                }

                if (currentMode !== 'zombie') {
                    ballVelocity.y -= GRAVITY * timeScale; ball.position.add(ballVelocity.clone().multiplyScalar(timeScale)); ballVelocity.multiplyScalar(0.98); 
                    let activeBounce = currentMode === 'basketball' ? -1.1 : -0.7; 
                    if (ball.position.y <= ballRadius) { ball.position.y = ballRadius; ballVelocity.y *= activeBounce; if (ballVelocity.y > 3.0) ballVelocity.y = 3.0; if (currentMode === 'basketball') { slowMoTimer = 0; timeScale = 1.0; } ballVelocity.x *= 0.9; ballVelocity.z *= 0.9; }
                    if (ball.position.x > fieldWidth/2 - ballRadius) { ball.position.x = fieldWidth/2 - ballRadius; ballVelocity.x *= -0.8; }
                    if (ball.position.x < -fieldWidth/2 + ballRadius) { ball.position.x = -fieldWidth/2 + ballRadius; ballVelocity.x *= -0.8; }
                    
                    if (currentMode === 'soccer') {
                        if (Math.abs(ball.position.x) > goalWidth/2 - ballRadius) {
                            if (ball.position.z > fieldLength/2 - ballRadius) { ball.position.z = fieldLength/2 - ballRadius; ballVelocity.z *= -0.8; }
                            if (ball.position.z < -fieldLength/2 + ballRadius) { ball.position.z = -fieldLength/2 + ballRadius; ballVelocity.z *= -0.8; }
                        } else {
                            if (ball.position.z > fieldLength/2 + goalDepth - ballRadius) { ball.position.z = fieldLength/2 + goalDepth - ballRadius; ballVelocity.z *= -0.8; }
                            if (ball.position.z < -fieldLength/2 - goalDepth + ballRadius) { ball.position.z = -fieldLength/2 - goalDepth + ballRadius; ballVelocity.z *= -0.8; }
                        }
                    } else if (currentMode !== 'basketball') {
                        if (ball.position.z > fieldLength/2 - ballRadius) { ball.position.z = fieldLength/2 - ballRadius; ballVelocity.z *= -0.8; }
                        if (ball.position.z < -fieldLength/2 + ballRadius) { ball.position.z = -fieldLength/2 + ballRadius; ballVelocity.z *= -0.8; }
                    }

                    if (currentMode === 'soccer') {
                        if (ball.position.z < -fieldLength/2 - goalDepth/2) triggerGoal(-fieldLength/2 - 5, 'p1', 0x00aaff);
                        if (ball.position.z > fieldLength/2 + goalDepth/2) triggerGoal(fieldLength/2 + 5, 'p2', 0xff0055);
                    } else if (currentMode === 'basketball') {
                        if (ball.position.distanceTo(hoop1.scoreZone) < 10 && ballVelocity.y < 0) triggerGoal(hoop1.scoreZone.z, 'p1', 0x00aaff);
                        if (ball.position.distanceTo(hoop2.scoreZone) < 10 && ballVelocity.y < 0) triggerGoal(hoop2.scoreZone.z, 'p2', 0xff0055);
                        if (ball.position.z > fieldLength/2 + 50 || ball.position.z < -fieldLength/2 - 50) { ball.position.set(0, 50, 0); ballVelocity.set(0,0,0); }
                    } else if (currentMode === 'volleyball') {
                        if (ball.position.y <= ballRadius + 0.5) { if (ball.position.z < 0) { triggerGoal(-10, 'p1', 0x00aaff); } else { triggerGoal(10, 'p2', 0xff0055); } }
                    }
                    ball.rotation.x += ballVelocity.z * 0.1 * timeScale; ball.rotation.z -= ballVelocity.x * 0.1 * timeScale;
                    ball.scale.lerp(new THREE.Vector3(ballTargetScale, ballTargetScale, ballTargetScale), 0.1); if(ballTargetScale > 1.0) ballTargetScale -= 0.05;
                }

                // CAMERA LOGIC
                if (gameSettings.firstPerson) {
                    let fpCamPos = player.position.clone().add(new THREE.Vector3(Math.sin(yawAngle) * 0.3, 2.3, Math.cos(yawAngle) * 0.3));
                    camera.position.copy(fpCamPos);
                    let lookAtTarget = fpCamPos.clone().add(new THREE.Vector3(Math.sin(yawAngle) * 10, Math.sin(pitchAngle) * 10, Math.cos(yawAngle) * 10));
                    camera.lookAt(lookAtTarget);
                } else {
                    let camDistance = 8; let camHeight = 4;    
                    let camOff = new THREE.Vector3(-Math.sin(yawAngle) * camDistance, camHeight, -Math.cos(yawAngle) * camDistance);
                    camera.position.lerp(player.position.clone().add(camOff), 0.3);
                    let lookAtTarget = player.position.clone().add(new THREE.Vector3(Math.sin(yawAngle) * 30, Math.sin(pitchAngle) * 30 + 5, Math.cos(yawAngle) * 30));
                    camera.lookAt(lookAtTarget);
                }
                if(cameraShake > 0) { camera.position.x += (Math.random()-0.5)*cameraShake; camera.position.y += (Math.random()-0.5)*cameraShake; camera.position.z += (Math.random()-0.5)*cameraShake; cameraShake *= 0.9; if(cameraShake < 0.05) cameraShake = 0; }
            }
            
            if (gameState === 'GOAL_CAM') { 
                camera.position.lerp(goalCamPos, 0.1); 
                camera.lookAt(goalCamLook); 
            }

            if (gameState === 'REPLAY') {
                if (historyBuffer.length > 0 && replayFrame < historyBuffer.length) {
                    let f = historyBuffer[replayFrame]; 
                    allies.forEach((a, i) => { if(f.allies[i]) { a.position.set(f.allies[i].x, f.allies[i].y, f.allies[i].z); a.rotation.y = f.allies[i].r; } });
                    enemies.forEach((e, i) => { if(f.enemies[i]) { e.position.set(f.enemies[i].x, f.enemies[i].y, f.enemies[i].z); e.rotation.y = f.enemies[i].r; } });
                    ball.position.set(f.b.x, f.b.y, f.b.z); ball.rotation.set(f.b.rx, f.b.ry, f.b.rz); 

                    // Render replay bullets
                    while(replayBulletMeshes.length < f.projs.length) { let bm = new THREE.Mesh(new THREE.CylinderGeometry(0.15, 0.15, 1.2, 8).rotateX(Math.PI/2), new THREE.MeshBasicMaterial()); scene.add(bm); replayBulletMeshes.push(bm); }
                    for(let i=0; i<replayBulletMeshes.length; i++) {
                        if (i < f.projs.length) {
                            replayBulletMeshes[i].visible = true; replayBulletMeshes[i].position.set(f.projs[i].x, f.projs[i].y, f.projs[i].z); replayBulletMeshes[i].rotation.set(f.projs[i].rx, f.projs[i].ry, f.projs[i].rz); replayBulletMeshes[i].material.color.setHex(f.projs[i].color);
                        } else { replayBulletMeshes[i].visible = false; }
                    }

                    // Dynamic Scorer Camera Logic
                    let ballPos = ball.position.clone();
                    let scorerPos = lastTouchChar ? lastTouchChar.position.clone() : new THREE.Vector3(0,0,0);
                    let midPoint = new THREE.Vector3().addVectors(scorerPos, ballPos).multiplyScalar(0.5);
                    let dir = new THREE.Vector3().subVectors(ballPos, scorerPos).normalize();
                    let perp = new THREE.Vector3(-dir.z, 0.5, dir.x).normalize().multiplyScalar(25); 
                    
                    let targetCamPos = midPoint.clone().add(perp); targetCamPos.y = 12;
                    camera.position.lerp(targetCamPos, 0.1);
                    camera.lookAt(midPoint);
                    
                    replayFrame++;
                } else { document.getElementById('replay-text').style.display = 'none'; replayBulletMeshes.forEach(m => m.visible = false); gameState = 'PLAYING'; resetField(); updateCrosshairVisibility(); }
            }

            for(let i = particles.length - 1; i >= 0; i--) {
                let p = particles[i]; p.mesh.position.add(p.vel.clone().multiplyScalar(timeScale));
                if(!p.isTrail) p.vel.y -= GRAVITY * timeScale;
                p.life -= 1 * timeScale; p.mesh.scale.setScalar(p.life / (p.maxLife || 45));
                if(p.life <= 0) { scene.remove(p.mesh); particles.splice(i, 1); }
            }

            renderer.render(scene, camera);
        }

        animate();
    </script>
</body>
</html>
